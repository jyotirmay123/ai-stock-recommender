# ─────────────────────────────────────────────────────────────────
# AI Stock Investment Recommender — Secrets Template
# ─────────────────────────────────────────────────────────────────
# Copy this file to .streamlit/secrets.toml and fill in your values.
# NEVER commit secrets.toml to git — it is in .gitignore.
# On Streamlit Cloud, paste these key=value pairs in:
#   App settings → Secrets
# ─────────────────────────────────────────────────────────────────

# ── App password (leave empty for open access / local dev) ───────
APP_PASSWORD = "change_me_to_your_password"

# ── Telegram bot (optional — leave empty to disable) ─────────────
# 1. Create a bot: message @BotFather on Telegram → /newbot
# 2. Copy the token it gives you
# 3. Start your bot, then visit:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    Find "chat" → "id" in the response — that is your chat_id
TELEGRAM_BOT_TOKEN = ""
TELEGRAM_CHAT_ID   = ""

# ── AI Screenshot OCR — pick ONE (or more, first configured wins) ─
#
# Option A: Anthropic Claude Haiku — you likely already have this key.
#   Cost: ~$0.001 per screenshot parse (near-zero). Best quality.
#   Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY = ""
#
# Option B: Google Gemini Flash — completely FREE (no credit card needed).
#   Free tier: 15 req/min, 1500 req/day — more than enough.
#   Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY = ""
#
# Option C: Groq + Llama 3.2 Vision — also FREE, very fast.
#   Free tier with generous limits. No credit card needed.
#   Get key: https://console.groq.com
GROQ_API_KEY = ""
